# Copy to /etc/reacnet-scope.env and adjust for the server.
REACNET_SCOPE_BIND=127.0.0.1:8060
REACNET_SCOPE_THREADS=4
REACNET_SCOPE_REQUEST_TIMEOUT=300
REACNET_SCOPE_LOG_LEVEL=info

# Put this on writable high-speed NVMe. Dataset mounts can remain read-only.
REACNET_SCOPE_CACHE_DIR=/srv/reacnet-cache

# Colon-separated read-only dataset roots visible in the Dash browser.
REACNET_SCOPE_ALLOWED_ROOTS=/srv/reacnet-data:/mnt/reacnet-data

