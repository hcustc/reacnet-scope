server {
    listen 80;
    server_name reacnet.example.org;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name reacnet.example.org;

    ssl_certificate /etc/letsencrypt/live/reacnet.example.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/reacnet.example.org/privkey.pem;

    auth_basic "ReacNet Scope";
    auth_basic_user_file /etc/nginx/reacnet-scope.htpasswd;

    client_max_body_size 1m;
    proxy_connect_timeout 10s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;

    location / {
        proxy_pass http://127.0.0.1:8060;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /api/health {
        proxy_pass http://127.0.0.1:8060/api/health;
        access_log off;
    }
}

